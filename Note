    <!-- ========================================== -->
    <!-- 3. JAVASCRIPT CONTROLLER ENGINE            -->
    <!-- ========================================== -->
    <script>
        const lockScreen = document.getElementById('lock-screen');
        const lockForm = document.getElementById('lock-form');
        const secretPassInput = document.getElementById('secret-pass');
        const notebookContainer = document.getElementById('notebook-container');

        const prevBtn = document.getElementById('prev-btn');
        const nextBtn = document.getElementById('next-btn');
        const currentPageNum = document.getElementById('current-page-num');
        const indicators = document.getElementById('page-indicators').children;

        // Default Secret Password (Tum isko badal bhi sakte ho)
        const correctPassword = "Reshma@123";
        
        let currentPage = 1;
        const totalPages = 4;

        // Password Check Logic
        lockForm.addEventListener('submit', (e) => {
            e.preventDefault();
            const enteredPassword = secretPassInput.value;

            if (enteredPassword === correctPassword) {
                // Unlock animation and hide lock screen
                lockScreen.classList.add('scale-95', 'opacity-0');
                setTimeout(() => {
                    lockScreen.classList.add('hidden');
                    // Show the premium notebook
                    notebookContainer.classList.remove('hidden');
                    notebookContainer.classList.add('animate-fade-in');
                }, 400);
            } else {
                alert("Incorrect Secret Password! ❌ (Ek baar hint check karo)");
                secretPassInput.value = "";
                secretPassInput.focus();
            }
        });

        // Page Turning Logic
        function updatePages() {
            // Loop through all 4 pages
            for (let i = 1; i <= totalPages; i++) {
                const page = document.getElementById(`page-${i}`);
                if (i === currentPage) {
                    page.classList.remove('page-hidden');
                    page.classList.add('page-active');
                    indicators[i-1].className = "w-1.5 h-1.5 rounded-full bg-pink-500 transition-all duration-300";
                } else {
                    page.classList.remove('page-active');
                    page.classList.add('page-hidden');
                    indicators[i-1].className = "w-1.5 h-1.5 rounded-full bg-zinc-800 transition-all duration-300";
                }
            }

            // Update Counter Text
            currentPageNum.textContent = currentPage;

            // Handle Previous Button State
            if (currentPage === 1) {
                prevBtn.classList.add('opacity-50', 'pointer-events-none');
            } else {
                prevBtn.classList.remove('opacity-50', 'pointer-events-none');
            }

            // Handle Next Button State text toggle
            if (currentPage === totalPages) {
                nextBtn.innerHTML = `Close Note <i class="fa-solid fa-heart-crack text-[10px] ml-1"></i>`;
            } else {
                nextBtn.innerHTML = `Next <i class="fa-solid fa-chevron-right text-[10px] ml-1"></i>`;
            }
        }

        nextBtn.onclick = () => {
            if (currentPage < totalPages) {
                currentPage++;
                updatePages();
            } else {
                // If clicked on last page close button
                alert("Thank you for reading! ✨ App closing...");
                location.reload();
            }
        };

        prevBtn.onclick = () => {
            if (currentPage > 1) {
                currentPage--;
                updatePages();
            }
        };
    </script>

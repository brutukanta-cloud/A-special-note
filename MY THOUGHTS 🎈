<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>A Special Note For You ✨</title>
    <!-- Tailwind CSS for Modern UI -->
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <!-- FontAwesome for Premium Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    <!-- Premium Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2 family=Dancing+Script:wght@700&family=Plus+Jakarta+Sans:wght@500;700;800&display=swap" rel="stylesheet">
    
    <style>
        body { font-family: 'Plus Jakarta Sans', sans-serif; background-color: #060609; }
        .handwritten { font-family: 'Dancing Script', cursive; }
        
        /* Smooth Page Swapping Animation Effect */
        .page-active { opacity: 1; transform: scale(1) translateY(0); pointer-events: auto; transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1); }
        .page-hidden { opacity: 0; transform: scale(0.95) translateY(10px); pointer-events: none; position: absolute; inset: 0; }

        /* Floating Emojis Animation for Premium Background Background */
        .emoji-bg { position: absolute; font-size: 20px; opacity: 0.15; animation: floatAround 8s infinite ease-in-out; pointer-events: none; }
        @keyframes floatAround {
            0% { transform: translateY(0px) rotate(0deg) scale(1); }
            50% { transform: translateY(-15px) rotate(20deg) scale(1.1); opacity: 0.25; }
            100% { transform: translateY(0px) rotate(0deg) scale(1); }
        }
    </style>
</head>
<body class="min-h-screen text-zinc-300 flex items-center justify-center p-4 relative overflow-hidden select-none">

    <!-- ========================================== -->
    <!-- PREMIUM AMBIENT BACKGROUND WITH FLOATING EMOJIS -->
    <!-- ========================================== -->
    <div class="absolute inset-0 bg-radial from-zinc-950 via-zinc-900 to-black z-0"></div>
    <div class="absolute top-[-10%] left-[-10%] w-[50vw] h-[50vw] bg-pink-600/10 rounded-full blur-[120px] pointer-events-none"></div>
    <div class="absolute bottom-[-10%] right-[-10%] w-[50vw] h-[50vw] bg-purple-600/10 rounded-full blur-[120px] pointer-events-none"></div>

    <!-- Distributed Floating Emojis across screen -->
    <div class="emoji-bg text-pink-400" style="top: 12%; left: 8%; animation-delay: 0s;">❤️</div>
    <div class="emoji-bg text-amber-300" style="top: 18%; right: 12%; animation-delay: 1.5s;">✨</div>
    <div class="emoji-bg text-rose-400" style="bottom: 15%; left: 14%; animation-delay: 3s;">🌸</div>
    <div class="emoji-bg text-yellow-200" style="bottom: 22%; right: 9%; animation-delay: 0.5s;">⭐</div>
    <div class="emoji-bg text-pink-500" style="top: 45%; left: 5%; animation-delay: 2.5s;">💖</div>
    <div class="emoji-bg text-purple-400" style="top: 50%; right: 6%; animation-delay: 4s;">✨</div>
    <div class="emoji-bg text-rose-300" style="bottom: 45%; left: 85%; animation-delay: 1s;">❤️</div>

    <!-- ========================================== -->
    <!-- MAIN INTERACTIVE NOTEBOOK CONTAINER        -->
    <!-- ========================================== -->
    <div id="notebook-container" class="w-full max-w-lg bg-zinc-950/90 backdrop-blur-xl border border-zinc-900 rounded-3xl p-6 md:p-8 shadow-2xl relative overflow-hidden flex flex-col justify-between min-h-[520px] z-10">
        
        <!-- Notebook Red Aesthetic Line & Page Binder Holes -->
        <div class="absolute left-6 top-0 bottom-0 w-[1px] bg-rose-500/20"></div>
        <div class="absolute left-2 top-12 flex flex-col gap-6 opacity-30">
            <div class="w-2 h-2 bg-zinc-800 rounded-full border border-zinc-700"></div>
            <div class="w-2 h-2 bg-zinc-800 rounded-full border border-zinc-700"></div>
            <div class="w-2 h-2 bg-zinc-800 rounded-full border border-zinc-700"></div>
        </div>

        <!-- Top Header Navigation Info -->
        <div class="flex justify-between items-center pl-6 pb-4 border-b border-zinc-900/60 mb-6">
            <span class="text-[10px] font-bold uppercase tracking-widest text-zinc-500"><i class="fa-solid fa-feather-pointed text-pink-500 mr-1"></i> Page <span id="current-page-num">1</span> of 5</span>
            <span class="text-[10px] font-bold uppercase tracking-widest text-zinc-500">A Personal Note ✨</span>
        </div>

        <!-- Dynamic Letter Content Pages Space -->
        <div class="relative flex-grow pl-6 min-h-[320px]">
            
            <!-- PAGE 1: WELCOME SCREEN (NO PASSWORD, DIRECT COZY ENTRY) -->
            <div id="page-1" class="page-active space-y-5 text-center pt-6">
                <div class="w-16 h-16 bg-gradient-to-tr from-pink-500/10 to-rose-500/10 border border-pink-500/20 rounded-2xl flex items-center justify-center mx-auto mb-2 text-pink-400 text-xl shadow-lg">
                    <i class="fa-solid fa-envelope-open-text animate-pulse"></i>
                </div>
                <h2 class="handwritten text-4xl text-white font-bold tracking-wide">Welcome Reshma ,</h2>
                <p class="text-zinc-400 text-xs max-w-xs mx-auto leading-relaxed font-medium">I have penned down some of my genuine thoughts and feelings for you. Please take a moment to flip through these pages. ✨</p>
                <p class="text-[10px] text-pink-500/60 uppercase font-bold tracking-widest pt-2">Click Next to open the note</p>
            </div>

            <!-- PAGE 2: MAIN PROPOSAL -->
            <div id="page-2" class="page-hidden space-y-4">
                <p class="text-zinc-300 text-sm leading-relaxed font-medium">I know ki unexpectedly message dekhi kari tui panic or nervous feel karuthibu and for that I apologize, but the reason behind it .... </p>
                <p class="text-zinc-300 text-sm leading-relaxed font-medium">Ita e ki - I wanna to say one thing to you and I hope ki pura padhbu .</p>
                <div class="pt-2">
                    <p class="handwritten text-4xl text-rose-400 font-bold text-center bg-rose-500/5 py-4 border border-rose-500/10 rounded-2xl shadow-inner">"You are my crush since class 6th."</p>
                </div>
            </div>

            <!-- PAGE 3: UNDERSTANDING -->
            <div id="page-3" class="page-hidden space-y-4">
                <p class="text-zinc-300 text-sm leading-relaxed font-medium">Dekh yarr mote bhi mor future ke dekhbar achhe au mui kebhe na chehe ki just for my emotions and feelings mor kam re kichhi affect padu au that's why mui eberu tote mor thinking au understanding tor nu kahinauchhe .</p>
                <p class="text-zinc-300 text-sm leading-relaxed font-medium">Januchhe ki Amar hete friendship na na hete relation na na hete tui mote na jani bele tk little insecure feel heba decision nebar lagi.</p>
                <p class="text-zinc-300 text-sm leading-relaxed font-medium">But life tor e mui kebhe jane ke force na kare tui jen decision nebu i agree 'cause Tor bhi kichhi choice thiba may be tui relation re bhi thibu kimba dar laguthiba .... </p>
            </div>

            <!-- PAGE 4: RESPECT & MATURITY -->
            <div id="page-4" class="page-hidden space-y-4">
                <p class="text-zinc-300 text-sm leading-relaxed font-medium">Ita bhi hei pare ki distrub hebar lagi na chahuthibu anything that can be happen but once I said - mui tote kete bele bhi force karbar lagi na chehe bar decision nebar lagi and I respect to your all decisions.</p>
                <p class="text-zinc-300 text-sm leading-relaxed font-medium">Au gute katha , tote laguthiba ki i sabu kam kale log bigdi jesan kimba takar career re affect padsi au mui agree bhi karsi but In my point of view..</p>
                <div class="bg-gradient-to-r from-purple-950/30 to-pink-950/30 border border-purple-500/20 p-4 rounded-xl shadow-lg my-1">
                    <p class="text-zinc-200 text-xs italic font-semibold leading-relaxed">"Love is not just an exchange of happiness and sadness. It is about how much you help someone grow, support their journey, and encourage them to reach greater heights in life."</p>
                </div>
            </div>

            <!-- PAGE 5: CONCLUSION & THANK YOU -->
            <div id="page-5" class="page-hidden space-y-4">
                <p class="text-zinc-300 text-sm leading-relaxed font-medium">That's the reason mui kebhe bhi mor happiness lagi tor use na kare for example:- ahade most of the people jenta chats au call or v call re just for their own happiness duhe duhikar use karsan.</p>
                <p class="text-zinc-300 text-sm leading-relaxed font-medium">But in the end - your life , your decision and I agree with your all words and I hope you will think about it and you can take time for this . These are my thoughts , thinking and feelings since class 6th baki mui kahineli choice tor ee.. 😄</p>
                <p class="text-zinc-300 text-xs text-zinc-500 pt-1">Etki jinis pare i know ki mote judge karbu baki mor all thoughts au thinking 4years ra kichhi page re ta express kari na pare jete important e sete kahebar ke try karichhe .</p>
                <p class="handwritten text-3xl text-pink-400 font-bold text-right mt-3">Thankyou ⭐</p>
            </div>

        </div>

        <!-- Bottom Controller Panel Buttons -->
        <div class="flex justify-between items-center pl-6 pt-4 border-t border-zinc-900/60 mt-6 z-10">
            <button id="prev-btn" class="bg-zinc-900 text-zinc-500 text-xs font-bold px-4 py-2.5 rounded-xl border border-zinc-800 opacity-50 pointer-events-none transition-all cursor-pointer">
                Prev
            </button>
            <div class="flex gap-1.5" id="page-indicators">
                <div class="w-1.5 h-1.5 rounded-full bg-pink-500"></div>
                <div class="w-1.5 h-1.5 rounded-full bg-zinc-800"></div>
                <div class="w-1.5 h-1.5 rounded-full bg-zinc-800"></div>
                <div class="w-1.5 h-1.5 rounded-full bg-zinc-800"></div>
                <div class="w-1.5 h-1.5 rounded-full bg-zinc-800"></div>
            </div>
            <button id="next-btn" class="bg-gradient-to-r from-pink-600 to-rose-600 text-white text-xs font-bold px-5 py-2.5 rounded-xl shadow-md cursor-pointer transition-all">
                Next <i class="fa-solid fa-chevron-right text-[10px] ml-1"></i>
            </button>
        </div>

    </div>

    <!-- ========================================== -->
    <!-- CONTROL ENGINE JAVASCRIPT                  -->
    <!-- ========================================== -->
    <script>
        const prevBtn = document.getElementById('prev-btn');
        const nextBtn = document.getElementById('next-btn');
        const currentPageNum = document.getElementById('current-page-num');
        const indicators = document.getElementById('page-indicators').children;

        let currentPage = 1;
        const totalPages = 5;

        function updatePages() {
            for (let i = 1; i <= totalPages; i++) {
                const pageElement = document.getElementById(`page-${i}`);
                if (i === currentPage) {
                    pageElement.classList.remove('page-hidden');
                    pageElement.classList.add('page-active');
                    indicators[i-1].className = "w-1.5 h-1.5 rounded-full bg-pink-500 transition-all duration-300";
                } else {
                    pageElement.classList.remove('page-active');
                    pageElement.classList.add('page-hidden');
                    indicators[i-1].className = "w-1.5 h-1.5 rounded-full bg-zinc-800 transition-all duration-300";
                }
            }

            currentPageNum.textContent = currentPage;

            // Manage Previous Button Visibility State
            if (currentPage === 1) {
                prevBtn.classList.add('opacity-50', 'pointer-events-none');
            } else {
                prevBtn.classList.remove('opacity-50', 'pointer-events-none');
            }

            // Toggle Text on the final page
            if (currentPage === totalPages) {
                nextBtn.innerHTML = `Close <i class="fa-solid fa-heart-crack text-[10px] ml-1"></i>`;
            } else {
                nextBtn.innerHTML = `Next <i class="fa-solid fa-chevron-right text-[10px] ml-1"></i>`;
            }
        }

        nextBtn.onclick = () => {
            if (currentPage < totalPages) {
                currentPage++;
                updatePages();
            } else {
                alert("Thank you for reading! ✨ Note closing...");
                location.reload();
            }
        };

        prevBtn.onclick = () => {
            if (currentPage > 1) {
                currentPage--;
                updatePages();
            }
        };
    </script>
</body>
</html>